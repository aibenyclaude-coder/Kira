{
  "name": "kira-telemetry-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --port 8787",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "migrate:local": "wrangler d1 execute kira-events-dev --local --file=migrations/0001_init.sql",
    "migrate:prod": "wrangler d1 execute kira-events-prod --remote --file=migrations/0001_init.sql"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.5.0",
    "@cloudflare/workers-types": "^4.20240924.0",
    "typescript": "^5.4.0",
    "vitest": "2.0.5",
    "wrangler": "^3.78.0"
  },
  "dependencies": {
    "zod": "^3.23.0"
  }
}
